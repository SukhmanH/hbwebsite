---
import Base from '../layouts/Base.astro';
import PhotoPlaceholder from '../components/PhotoPlaceholder.astro';
import { sites } from '../data/sites';

const farming = [
  {
    title: 'Hand work where it counts',
    body:
      'Pruning, shoot thinning, and crop drops are done by hand on every block. Machines have their place; deciding what fruit stays on the vine isn’t one of them.',
  },
  {
    title: 'Drip irrigation, measured twice',
    body:
      'The South Okanagan gets less rain than some deserts. Every site runs on drip with soil-moisture probes, and we water to the vine’s need — not the calendar.',
  },
  {
    title: 'Living rows',
    body:
      'Cover crops between the rows feed the soil and hold it on the slopes. Integrated pest management keeps spraying to what’s needed, when it’s needed.',
  },
  {
    title: 'Picked on flavour',
    body:
      'Numbers get fruit close; taste gets it right. We walk rows with our winery partners in the weeks before harvest and pick each block on its own schedule.',
  },
];
---

<Base
  title="The Vineyards — H.B. Bro's Vineyards"
  description="Five vineyard sites across 56 kilometres of the South Okanagan — Naramata Bench, Skaha Bench, Okanagan Falls, Golden Mile Bench, and Black Sage Bench. Soils, varieties, and farming practices."
>
  <!-- Page header -->
  <section class="mx-auto max-w-6xl px-5 pb-16 pt-20 sm:px-8 sm:pt-28">
    <p class="eyebrow hero-rise">The vineyards</p>
    <h1 class="display-xl hero-rise mt-4 max-w-3xl" style="--rise-delay: 120ms;">
      Fifty-six kilometres of valley, top to bottom
    </h1>
    <p class="hero-rise prose-col mt-6 text-lg text-ink-700" style="--rise-delay: 240ms;">
      The run starts on clay bluffs above Okanagan Lake and ends in deep sand
      where the sagebrush takes over. Every site below is farmed by our family,
      and every one grows what its ground does best.
    </p>
  </section>

  <!-- Sites, north to south -->
  <section class="mx-auto max-w-6xl px-5 pb-4 sm:px-8">
    <ol class="flex flex-col gap-20 sm:gap-28">
      {
        sites.map((site, i) => (
          <li class="grid items-center gap-10 lg:grid-cols-2">
            <PhotoPlaceholder
              caption={`${site.name} — ${site.soils.toLowerCase()}`}
              variant={site.variant}
              class:list={[
                'reveal aspect-[4/3] w-full',
                i % 2 === 1 && 'lg:order-2',
              ]}
            />
            <div class="reveal" style="--reveal-delay: 120ms;">
              <p class="tabular text-[0.7rem] font-bold uppercase tracking-[0.22em] text-clay-500">
                km {site.km} on the run &middot; {site.locality}
              </p>
              <h2 class="display-lg mt-3">{site.name}</h2>
              <p class="prose-col mt-5 text-ink-700">{site.note}</p>

              <dl class="mt-7 grid gap-5 border-t rule pt-6 sm:grid-cols-2">
                <div>
                  <dt class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-olive-500">
                    Soils
                  </dt>
                  <dd class="mt-1.5 text-sm text-ink-700">{site.soils}</dd>
                </div>
                <div>
                  <dt class="text-[0.68rem] font-bold uppercase tracking-[0.18em] text-olive-500">
                    Planted to
                  </dt>
                  <dd class="mt-1.5 flex flex-wrap gap-1.5">
                    {site.grapes.map((g) => (
                      <span class="rounded-[2px] border rule bg-bone-50 px-2.5 py-1 text-xs text-ink-700">
                        {g}
                      </span>
                    ))}
                  </dd>
                </div>
              </dl>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Farming practices -->
  <section class="mt-20 bg-vine-950 py-20 text-bone-100 sm:py-28">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <div class="reveal max-w-2xl">
        <p class="eyebrow eyebrow--light">Farming practices</p>
        <h2 class="display-lg mt-4 text-bone-50">
          How the fruit gets this good
        </h2>
        <p class="mt-5 text-bone-200/90">
          Growing for winemakers means every decision in the field shows up in
          somebody&rsquo;s bottle. These are the habits we keep on all five
          sites, every season.
        </p>
      </div>

      <div class="mt-12 grid gap-x-12 gap-y-10 sm:grid-cols-2">
        {
          farming.map(({ title, body }, i) => (
            <article
              class="reveal border-t border-gold-400/40 pt-5"
              style={`--reveal-delay: ${(i % 2) * 110}ms;`}
            >
              <h3 class="font-display text-xl font-medium text-gold-300" style="font-variation-settings: 'opsz' 40, 'SOFT' 40;">
                {title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-bone-200/85">{body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="reveal flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="display-md max-w-lg">
          Interested in fruit from a particular bench?
        </h2>
        <p class="mt-3 max-w-md text-ink-700">
          Contracts are arranged by block and by variety. The earlier in the
          season we talk, the more options you&rsquo;ll have.
        </p>
      </div>
      <a href="/contact" class="btn btn-clay shrink-0">Get in touch</a>
    </div>
  </section>
</Base>
