---
import Base from '../layouts/Base.astro';

const CONTACT_EMAIL = 'info@hbbrosvineyards.com';
---

<Base
  title="Contact — H.B. Bro's Vineyards"
  description="Get in touch with H.B. Bro's Vineyards about grape contracts, fruit availability, or anything else. Family-owned vineyard sites from Naramata to Oliver, BC."
>
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-20 sm:px-8 sm:pt-28">
    <div class="grid gap-14 lg:grid-cols-[1fr_1.2fr]">
      <!-- Direct details -->
      <div>
        <p class="eyebrow hero-rise">Contact</p>
        <h1 class="display-xl hero-rise mt-4" style="--rise-delay: 120ms;">
          Talk to the family
        </h1>
        <p class="hero-rise prose-col mt-6 text-lg text-ink-700" style="--rise-delay: 240ms;">
          Whether you&rsquo;re a winemaker looking for fruit, a neighbour with
          a question, or somebody who just wants to know more about what we
          do &mdash; write to us. A person answers, not a department.
        </p>

        <dl class="hero-rise mt-10 flex flex-col gap-6 border-t rule pt-8" style="--rise-delay: 360ms;">
          <div>
            <dt class="text-[0.7rem] font-bold uppercase tracking-[0.18em] text-olive-500">
              Email
            </dt>
            <dd class="mt-1">
              <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="font-display text-xl text-vine-900 underline decoration-gold-400 decoration-2 underline-offset-4 transition-colors hover:text-clay-500"
                style="font-variation-settings: 'opsz' 40;"
              >
                {CONTACT_EMAIL}
              </a>
            </dd>
          </div>
          <div>
            <dt class="text-[0.7rem] font-bold uppercase tracking-[0.18em] text-olive-500">
              Where we are
            </dt>
            <dd class="mt-1 text-ink-700">
              Home block in Oliver, BC — with sites up the valley through
              Okanagan Falls, Kaleden, and Naramata.
            </dd>
          </div>
          <div>
            <dt class="text-[0.7rem] font-bold uppercase tracking-[0.18em] text-olive-500">
              Grape contracts
            </dt>
            <dd class="mt-1 text-ink-700">
              Enquiries for next vintage are best made before bud break.
              Tell us the variety and tonnage you&rsquo;re after.
            </dd>
          </div>
        </dl>
      </div>

      <!-- Form -->
      <div class="hero-rise" style="--rise-delay: 300ms;">
        <form
          id="contact-form"
          class="flex flex-col gap-6 border rule bg-bone-50 p-7 sm:p-9"
        >
          <div class="flex flex-col gap-2">
            <label for="name" class="text-[0.75rem] font-bold uppercase tracking-[0.14em] text-vine-900">
              Your name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="rounded-[2px] border rule bg-bone-100 px-4 py-3 text-ink-900 placeholder:text-olive-400"
              placeholder="Jane Winemaker"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-[0.75rem] font-bold uppercase tracking-[0.14em] text-vine-900">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="rounded-[2px] border rule bg-bone-100 px-4 py-3 text-ink-900 placeholder:text-olive-400"
              placeholder="you@winery.com"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="topic" class="text-[0.75rem] font-bold uppercase tracking-[0.14em] text-vine-900">
              What's this about?
            </label>
            <select
              id="topic"
              name="topic"
              class="rounded-[2px] border rule bg-bone-100 px-4 py-3 text-ink-900"
            >
              <option>Grape contracts &amp; fruit availability</option>
              <option>Vineyard services &amp; custom farming</option>
              <option>General enquiry</option>
            </select>
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-[0.75rem] font-bold uppercase tracking-[0.14em] text-vine-900">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="rounded-[2px] border rule bg-bone-100 px-4 py-3 text-ink-900 placeholder:text-olive-400"
              placeholder="Variety, tonnage, timing — or just say hello."></textarea>
          </div>

          <button type="submit" class="btn btn-clay self-start">Send message</button>

          <p class="text-xs leading-relaxed text-olive-500">
            Sending opens your email app with the message addressed to us —
            nothing is stored on this site. Prefer to write directly? Use the
            address on the left.
          </p>
        </form>
      </div>
    </div>
  </section>

  <script define:vars={{ CONTACT_EMAIL }}>
    // Static-host contact form: package the fields into a mailto: handoff.
    // Swap for a Cloudflare Pages Function or Formspree endpoint to capture
    // submissions server-side.
    const form = document.getElementById('contact-form');
    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const subject = `[${data.get('topic')}] Website enquiry from ${data.get('name')}`;
      const body = [
        `Name: ${data.get('name')}`,
        `Email: ${data.get('email')}`,
        '',
        String(data.get('message')),
      ].join('\n');
      window.location.href = `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</Base>
