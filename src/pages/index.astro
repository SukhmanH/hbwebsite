---
import Base from '../layouts/Base.astro';
---

<Base
  title="H.B. Bro's Vineyards — Under Development"
  description="The H.B. Bro's Vineyards website is currently under development."
>
  <section class="px-5 py-20 sm:px-8 sm:py-28">
    <div class="mx-auto flex min-h-[70vh] max-w-4xl flex-col items-center justify-center rounded-[2px] border border-vine-900/15 bg-bone-50/80 px-6 py-16 text-center shadow-[0_18px_60px_rgba(32,41,32,0.08)] sm:px-10 lg:px-16">
      <div class="mb-8 flex h-20 w-20 items-center justify-center rounded-full border border-vine-900/15 bg-vine-900/5">
        <svg
          aria-hidden="true"
          viewBox="0 0 64 64"
          class="h-10 w-10 text-clay-500"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="18" y="28" width="28" height="20" rx="4" />
          <path d="M24 28V22a8 8 0 1 1 16 0v6" />
          <circle cx="32" cy="38" r="2.5" />
        </svg>
      </div>

      <p class="eyebrow">Currently in progress</p>
      <h1 class="display-xl mt-4">Under development</h1>
      <p class="prose-col mt-6 text-lg text-ink-700">
        This site is being refreshed to better reflect the farm, the vineyards,
        and the work behind every vintage. Please check back soon.
      </p>

      <a href="/contact" class="btn btn-clay mt-8">Get in touch</a>
    </div>
  </section>
</Base>
